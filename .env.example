# Hardin Trading Software v2 — One Big Trade Per Day
ALPACA_API_KEY=your_new_api_key
ALPACA_SECRET_KEY=your_new_secret_key
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# Position sizing — go big on high conviction
POSITION_SIZE=60000        # dollars per trade
MIN_PROFIT_PCT=1.0         # minimum take profit %
MAX_PROFIT_PCT=3.0         # let it run up to 3%
STOP_LOSS_PCT=0.5          # tight stop — 0.5% max loss
MAX_DAILY_TRADES=1         # ONE trade per day only
MIN_SIGNAL_SCORE=8         # only fire on very high conviction setups
